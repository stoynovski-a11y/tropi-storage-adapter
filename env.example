# Storage adapter — environment template
# Copy this file to .env and fill in values. NEVER commit .env.
#
# (Filename uses no leading dot to keep it safely editable; rename to .env locally.)

# -----------------------------------------------------------------------------
# Backend selection
# -----------------------------------------------------------------------------
STORAGE_BACKEND=dropbox  # or "m365"

# -----------------------------------------------------------------------------
# Dropbox (used when STORAGE_BACKEND=dropbox)
# -----------------------------------------------------------------------------
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=

# -----------------------------------------------------------------------------
# Microsoft 365 (used when STORAGE_BACKEND=m365)
# -----------------------------------------------------------------------------
M365_TENANT_ID=
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_SITE_HOSTNAME=yourcompany.sharepoint.com
M365_SITE_PATH=/sites/YourSite

# -----------------------------------------------------------------------------
# Logging / observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Retry behavior
# -----------------------------------------------------------------------------
STORAGE_MAX_RETRIES=5

# -----------------------------------------------------------------------------
# Integration tests
# -----------------------------------------------------------------------------
INTEGRATION_TESTS=0  # set to 1 to run live tests against a real backend
